        <p id="copyFeedback" class="text-[var(--accent)] mt-3 opacity-0 transition-opacity duration-300" aria-live="polite"></p>
      </section>
    </main>
    <footer class="text-center py-8 text-[var(--muted)] text-sm">
      <p>Feito com amor e esperanca de encontrar Thor</p>
      <p class="mt-2">Compartilhe este anuncio para ajudar</p>
    </footer>
  </div>
  <script>
    const pageData = {
      title: 'PROCURA-SE TICO E TECA - Cachorro Perdido',
      url: window.location.href,
      text: 'AJUDE! Cachorro perdido na Av. Paulista, Sao Paulo. Golden Retriever, responde por Thor. Contato: (98) 98824-8877'
    };
    function initRevealAnimations() {
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion) {
        document.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
        return;
      }
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const delay = parseInt(entry.target.dataset.delay) || 0;
            setTimeout(() => entry.target.classList.add('visible'), delay);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    }
    function showFeedback(message) {
      const feedback = document.getElementById('copyFeedback');
      feedback.textContent = message;
      feedback.style.opacity = '1';
      setTimeout(() => feedback.style.opacity = '0', 3000);
    }
    function copyLink() {
      navigator.clipboard.writeText(pageData.url).then(() => {
        showFeedback('Link copiado!');
      });
    }
    function shareInstagram() {
      // Instagram não suporte compartilhamento direto via URL como Facebook/Twitter
      // A melhor experiência é copiar o link e orientar o usuário
      navigator.clipboard.writeText(pageData.url).then(() => {
        showFeedback('Link copiado! Abra o Instagram para colar.');
      });
    }
    function shareTwitter() {
      const text = encodeURIComponent(pageData.text);
      const url = encodeURIComponent(pageData.url);
      window.open(`https://twitter.com/intent/tweet?text=${text}&url=${url}`, '_blank', 'width=600,height=400');
    }
    document.addEventListener('DOMContentLoaded', initRevealAnimations);
  </script>
</body>
</html>
